// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================
// Better Auth Models
// =========================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom fields for SmartStay
  phone      String?
  role       UserRole?
  verified   Boolean   @default(false)
  lastLogin  DateTime?
  signupDate DateTime? @default(now())

  // Better Auth relations
  accounts Account[]
  sessions Session[]

  // App relations
  properties         Property[]
  favorites          Favorite[]
  bookings           Booking[]
  reviews            Review[]
  inquiries          Inquiry[]
  notifications      Notification[]
  propertyViewEvents PropertyViewEvent[]
  bookingEvents      BookingEvent[]
  inquiryEvents      InquiryEvent[]

  @@map("user")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// =========================================
// OTP Verification (Custom for SmartStay)
// =========================================

model OtpVerification {
  id        String    @id @default(cuid())
  email     String    @unique
  otp       String
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@map("otp_verification")
}

// =========================================
// Property Models
// =========================================

model Property {
  id             String         @id @default(cuid())
  title          String
  description    String?
  location       String
  latitude       Float?
  longitude      Float?
  price          Float
  deposit        Float?
  type           PropertyType
  status         PropertyStatus @default(ACTIVE)
  bedrooms       Int            @default(1)
  bathrooms      Float          @default(1)
  availableFrom  DateTime?
  virtualTourUrl String?
  seoKeywords    String?
  contactPhone   String?
  contactEmail   String?
  utilities      Boolean        @default(false)
  petFriendly    Boolean        @default(false)
  furnished      Boolean        @default(false)
  parking        Boolean        @default(false)
  views          Int            @default(0)
  rating         Float          @default(0)
  earnings       Float          @default(0)
  occupancy      Int            @default(0)
  lastUpdated    DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  ownerId       String
  owner         User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images        PropertyImage[]
  amenities     PropertyAmenity[]
  favorites     Favorite[]
  bookings      Booking[]
  reviews       Review[]
  inquiries     Inquiry[]
  viewEvents    PropertyViewEvent[]
  bookingEvents BookingEvent[]
  inquiryEvents InquiryEvent[]

  @@index([status])
  @@index([type])
  @@index([price])
  @@index([rating])
  @@index([createdAt])
  @@index([ownerId])
  @@index([location])
  @@map("property")
}

model PropertyImage {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([order])
  @@map("property_image")
}

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties PropertyAmenity[]

  @@map("amenity")
}

model PropertyAmenity {
  id String @id @default(cuid())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenityId  String
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityId])
  @@index([propertyId])
  @@index([amenityId])
  @@map("property_amenity")
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("favorite")
}

model Booking {
  id        String        @id @default(cuid())
  startDate DateTime
  endDate   DateTime?
  status    BookingStatus @default(PENDING)
  amount    Float
  deposit   Float?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@map("booking")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([rating])
  @@map("review")
}

model Inquiry {
  id        String        @id @default(cuid())
  message   String
  status    InquiryStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@map("inquiry")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notification")
}

// =========================================
// Analytics Events
// =========================================

model PropertyViewEvent {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp  DateTime @default(now())
  metadata   Json?

  @@index([propertyId])
  @@index([timestamp])
  @@map("property_view_event")
}

model BookingEvent {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId  String?
  timestamp  DateTime @default(now())
  metadata   Json?

  @@index([propertyId])
  @@index([timestamp])
  @@map("booking_event")
}

model InquiryEvent {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  inquiryId  String?
  timestamp  DateTime @default(now())
  metadata   Json?

  @@index([propertyId])
  @@index([timestamp])
  @@map("inquiry_event")
}

// =========================================
// Enums
// =========================================

enum UserRole {
  STUDENT
  LANDLORD
  ADMIN
}

enum PropertyType {
  APARTMENT
  STUDIO
  SHARED_HOUSE
  LUXURY
  ROOM
  FAMILY_HOME
  HOSTEL
  PG
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  PENDING
  RENTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum InquiryStatus {
  PENDING
  RESPONDED
  CLOSED
}

enum NotificationType {
  BOOKING
  INQUIRY
  REVIEW
  PAYMENT
  SYSTEM
}
