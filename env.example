# ──────────────────────────────────────────────────────────────────────────
# SmartStay environment variables
# Copy to `.env` for local dev (it is gitignored). Set the same keys in your
# deploy platform (e.g. Vercel → Project → Settings → Environment Variables).
# Every key below is read by the code; NODE_ENV / NEXT_PHASE are set by Next.js
# automatically and must NOT be set by hand.
# ──────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──
# Postgres connection string used by Prisma (prisma/schema.prisma).
DATABASE_URL="postgresql://username:password@host:5432/smartstay?sslmode=require"

# ── Better Auth (REQUIRED) ──
# Public base URL of the app. Locally http://localhost:3000; in prod your domain.
BETTER_AUTH_URL="http://localhost:3000"
# Secret used to sign sessions. REQUIRED in production — the app throws on
# startup if missing. Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET="generate-a-strong-random-32-byte-value"

# Public base URL exposed to auth trustedOrigins and the same-origin (CSRF)
# check on sensitive routes (change-password, delete-account). Set this to the
# SAME value as BETTER_AUTH_URL (your real domain in production). REQUIRED so
# the CSRF origin check has an allowlist entry.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Scheduled OTP cleanup (REQUIRED for the cron to run) ──
# Protects GET/POST /api/auth/cleanup-otp. Without it the endpoint is DISABLED
# (fails closed). Vercel Cron auto-sends `Authorization: Bearer $CRON_SECRET`.
# Generate one with:  openssl rand -base64 32
CRON_SECRET="generate-a-strong-random-value"

# ── Email / OTP delivery (REQUIRED for signup OTP emails) ──
# For Gmail use an App Password (needs 2FA enabled), not your account password:
# Google Account → Security → App passwords → Mail.
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-gmail-app-password"

# ── Google OAuth (OPTIONAL — only if Google sign-in is enabled) ──
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
