# Email Configuration for OTP
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Note: For Gmail, you need to use an "App Password" not your regular password
# To get an App Password:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to Google Account settings > Security > App passwords
# 3. Generate a new app password for "Mail"
# 4. Use that password here

# Better Auth Configuration
BETTER_AUTH_URL=http://localhost:3000
# REQUIRED in production: the app throws on startup if this is missing.
# Generate a strong random value, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=your-better-auth-secret-key-here

# Public base URL of the deployed app. Used for auth trustedOrigins and the
# same-origin (CSRF) check on sensitive routes. Set to your production URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for protecting the scheduled OTP-cleanup endpoint (/api/auth/cleanup-otp).
# REQUIRED for cleanup to run: without it the endpoint is disabled (fails closed).
# Vercel Cron automatically sends `Authorization: Bearer $CRON_SECRET`.
# Generate with `openssl rand -base64 32`.
CRON_SECRET=your-cron-secret-here

# Google OAuth (if using Google sign-in)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/smartstay"
